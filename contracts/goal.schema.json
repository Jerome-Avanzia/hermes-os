{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-os.dev/contracts/goal.schema.json",
  "title": "Goal",
  "description": "Canonical Hermes OS Goal object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal_id",
    "business_id",
    "title",
    "target_date",
    "status"
  ],
  "properties": {
    "goal_id": {
      "type": "string"
    },
    "business_id": {
      "type": "string"
    },
    "strategy_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "target_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "active",
        "completed",
        "cancelled"
      ]
    },
    "owner": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}