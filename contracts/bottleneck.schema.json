{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-os.dev/contracts/bottleneck.schema.json",
  "title": "Bottleneck",
  "description": "Canonical Hermes OS Bottleneck object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bottleneck_id",
    "business_id",
    "title",
    "category",
    "impact",
    "status"
  ],
  "properties": {
    "bottleneck_id": {
      "type": "string"
    },
    "business_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "product",
        "marketing",
        "sales",
        "operations",
        "finance",
        "technology"
      ]
    },
    "impact": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "owner": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "mitigating",
        "resolved"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}