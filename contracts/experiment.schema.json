{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-os.dev/contracts/experiment.schema.json",
  "title": "Experiment",
  "description": "Canonical Hermes OS Experiment object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_id",
    "business_id",
    "title",
    "hypothesis",
    "success_criteria",
    "status"
  ],
  "properties": {
    "experiment_id": {
      "type": "string"
    },
    "business_id": {
      "type": "string"
    },
    "opportunity_id": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "success_criteria": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "inconclusive"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "completed",
        "cancelled"
      ]
    },
    "owner": {
      "type": "string"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}