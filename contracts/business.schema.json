{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-os.dev/contracts/business.schema.json",
  "title": "Business",
  "description": "Canonical Hermes OS Business object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "business_id",
    "name",
    "mission",
    "status",
    "created_at"
  ],
  "properties": {
    "business_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "mission": {
      "type": "string"
    },
    "vision": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "paused",
        "archived"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}