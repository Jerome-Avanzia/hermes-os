{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-os.dev/contracts/opportunity.schema.json",
  "title": "Opportunity",
  "description": "Canonical Hermes OS Opportunity object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "opportunity_id",
    "business_id",
    "title",
    "description",
    "expected_impact",
    "estimated_effort",
    "owner",
    "status"
  ],
  "properties": {
    "opportunity_id": {
      "type": "string"
    },
    "business_id": {
      "type": "string"
    },
    "strategy_id": {
      "type": "string"
    },
    "goal_id": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "experiment_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "expected_impact": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "estimated_effort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "owner": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "backlog",
        "planned",
        "active",
        "completed",
        "rejected"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
